// Test operator precedence
// Expected parse trees are shown in comments

// Test 1: Multiplication before addition
// Should parse as: a = (2 * 3) + 4 = 10
private a = 2 * 3 + 4

// Test 2: Addition is left-to-right at same level
// Should parse as: b = ((1 + 2) + 3) + 4 = 10
private b = 1 + 2 + 3 + 4

// Test 3: Multiple levels
// Should parse as: c = (2 + (3 * 4)) - 1 = 13
private c = 2 + 3 * 4 - 1

// Test 4: Comparison before logical AND
// Should parse as: d = (x > 5) & (y < 10)
private d = x > 5 & y < 10

// Test 5: Logical AND before OR
// Should parse as: e = a | (b & c)
private e = a | b & c

// Test 6: All levels together
// Should parse as: f = (1 + (2 * 3)) > ((4 - 1) * 2)
private f = 1 + 2 * 3 > 4 - 1 * 2

// Test 7: Equality after comparison
// Should parse as: g = (a < b) == (c > d)
private g = a < b == c > d

// Test 8: Division and modulo (same precedence as multiplication)
// Should parse as: h = ((10 / 2) * 3) % 7 = 1
private h = 10 / 2 * 3 % 7
